# Required
TELEGRAM_BOT_TOKEN=           # Main bot token from @BotFather
ASSISTANT_NAME=Tetsuclaw      # Bot display name
TZ=Asia/Tokyo                 # Timezone

# Agent Pool (optional but recommended — gives each agent its own bot identity)
TELEGRAM_BOT_POOL=            # Comma-separated pool bot tokens (e.g., token1,token2,token3)

# Credentials Gateway
ONECLI_URL=http://127.0.0.1:10254

# Optional integrations
OPENAI_API_KEY=               # For voice transcription (Whisper)
OLLAMA_HOST=                  # Local LLM (optional)
SLACK_BOT_TOKEN=              # Slack channel (optional)
SLACK_APP_TOKEN=              # Slack channel (optional)
ASSISTANT_HAS_OWN_NUMBER=    # WhatsApp channel (optional)
