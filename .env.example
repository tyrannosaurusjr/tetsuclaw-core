# Required
TELEGRAM_BOT_TOKEN=           # Main bot token from @BotFather
ASSISTANT_NAME=Tetsuclaw      # Bot display name
TZ=Asia/Tokyo                 # Timezone

# Agent Pool (optional but recommended — gives each agent its own bot identity)
TELEGRAM_BOT_POOL=            # Comma-separated pool bot tokens (e.g., token1,token2,token3)

# Credentials Gateway
ONECLI_URL=http://127.0.0.1:10254

# Optional integrations
OPENAI_API_KEY=               # For voice transcription (Whisper)
OLLAMA_HOST=                  # Local LLM (optional)
MODEL_PROVIDER_ORDER=codex,gemini,ollama,claude  # Host model fallback order for model_ask(auto)
CODEX_BIN=                    # Optional path to Codex CLI; defaults to codex
CODEX_MODEL=                  # Optional Codex model override
GEMINI_BIN=                   # Optional path to Gemini CLI; defaults to gemini
GEMINI_MODEL=                 # Optional Gemini model override
OLLAMA_MODEL=                 # Optional Ollama model override
CLAUDE_BIN=                   # Optional path to Claude CLI; defaults to claude
CLAUDE_MODEL=                 # Optional Claude model override for model_ask(claude)
SLACK_BOT_TOKEN=              # Slack channel (optional)
SLACK_APP_TOKEN=              # Slack channel (optional)
ASSISTANT_HAS_OWN_NUMBER=    # WhatsApp channel (optional)

# Stripe webhook receiver (optional — only starts if STRIPE_WEBHOOK_SECRET is set)
STRIPE_WEBHOOK_SECRET=        # whsec_... from Stripe dashboard → Developers → Webhooks
STRIPE_WEBHOOK_PORT=3101      # Port the receiver listens on (default 3101)
STRIPE_EXPORT_GROUP=main      # Group folder that gets user/transactions.json mirrored
